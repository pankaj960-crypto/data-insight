# Local dev (no PostgreSQL required):
DATABASE_URL=sqlite+aiosqlite:///./datainsight.db
DATABASE_URL_SYNC=sqlite:///./datainsight.db
# Production / Docker:
# DATABASE_URL=postgresql+asyncpg://datainsight:datainsight@localhost:5432/datainsight
# DATABASE_URL_SYNC=postgresql://datainsight:datainsight@localhost:5432/datainsight
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_PER_MINUTE=60
ENVIRONMENT=development
